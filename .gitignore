# Showcase Repository .gitignore

# Environment Variables (NEVER COMMIT)
.env
.env.local
.env.development
.env.production
.env.test
*.env

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Build outputs
.next/
out/
build/
dist/

# Logs
logs/
*.log
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Testing
coverage/
.nyc_output/
*.lcov

# IDEs and editors
.idea/
.vscode/
*.swp
*.swo
*~

# Temporary files
tmp/
temp/
*.tmp

# Uploads and user-generated content
uploads/
public/uploads/

# Database
*.sqlite
*.sqlite3
*.db

# Cache
.cache/
.parcel-cache/

# Misc
.vercel
.turbo

# OS
.DS_Store
Thumbs.db
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Sensitive files (NEVER COMMIT)
*secret*
*private*
*credential*
*password*
*token*
*key.pem
*.key
*.cert
*.crt

# Backup files
*.bak
*.backup
*~

# Debug files
debug/
scratch/
test-data/

# Production files (if any)
production/
prod/
